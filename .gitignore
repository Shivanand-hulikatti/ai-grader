# Go binaries
bin/
./bin

web/node_modules/
web/dist/

# Environment files
.env
.env.local
.env.development.local

# Ignore all log files and keep the logs directory
logs/
!logs/.keep
# Ignore all files in the public directory except for .keep
public/*
!public/.keep
# Ignore all files in the src directory except for .keep
src/*
!src/.keep
# Ignore all files in the config directory except for .keep
config/*
!config/.keep

# Python / OCR service
ocr-service/.venv/
ocr-service/venv/
ocr-service/__pycache__/
ocr-service/**/__pycache__/
ocr-service/*.pyc
ocr-service/**/*.pyc
ocr-service/*.pyo
ocr-service/.pytest_cache/
ocr-service/.mypy_cache/
ocr-service/dist/
ocr-service/build/
ocr-service/*.egg-info/

# PaddleOCR downloads model weights into ~/.paddleocr by default; if you
# override PADDLE_HOME to a local path, make sure it is ignored too.
ocr-service/.paddleocr/
ocr-service/paddleocr_output/
ocr-service/inference/