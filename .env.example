# Database Configuration
DATABASE_URL=postgresql://ai-grader:ai-grader@localhost:5432/ai_grader?sslmode=disable

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production

# Service Ports
GATEWAY_PORT=8080
UPLOAD_SERVICE_PORT=8081
GRADER_SERVICE_PORT=8082
RESULTS_SERVICE_PORT=8083

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=ai-grader-uploads

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=paper-uploaded

# File Upload Limits
MAX_FILE_SIZE_MB=25
