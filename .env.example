# Database Configuration
DATABASE_URL=postgresql://ai-grader:ai-grader@localhost:5432/ai_grader?sslmode=disable

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production

# Service Ports
GATEWAY_PORT=8080
UPLOAD_SERVICE_PORT=8081
GRADER_SERVICE_PORT=8082
RESULTS_SERVICE_PORT=8083

# AWS S3 Configuration
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=paper-uploaded
KAFKA_GRADED_TOPIC=paper-graded
KAFKA_CONSUMER_GROUP_ID=grader-consumer-group

# Grading AI Configuration
GOOGLE_VISION_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
GLOBAL_GRADING_RUBRIC="Content accuracy 40%, clarity 20%, structure 20%, examples 20%"
# File Upload Limits
MAX_FILE_SIZE_MB=25
